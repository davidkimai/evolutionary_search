{
  "name": "open-web-evolutionary-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex-native Open Web Evolutionary Search with opportunity discovery as the first wedge.",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "start:dist": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "cli": "tsx src/cli.ts",
    "demo:replay": "tsx src/cli.ts demo replay",
    "demo:live": "tsx src/cli.ts demo live",
    "export:demo": "tsx src/cli.ts demo export",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "tsx src/cli.ts smoke"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
